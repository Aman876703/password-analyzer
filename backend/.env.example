# Express Server Configuration
PORT=5000
NODE_ENV=development

# ML Backend Configuration
ML_API_URL=https://password-analyzer-k3gi.onrender.com
JWT_SECRET=mysecretkey

# Optional: API Key for securing endpoints
# API_KEY=your-secret-api-key-here

# Optional: Database Configuration (for future enhancements)
# DATABASE_URL=postgresql://user:password@localhost/password_analyzer

# Optional: Redis Cache Configuration
# REDIS_URL=redis://localhost:6379

# Optional: Email Configuration (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Optional: Sentry Error Tracking
# SENTRY_DSN=https://...@sentry.io/...

# Logging
# LOG_LEVEL=debug
